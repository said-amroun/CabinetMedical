<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_medical" model="ir.module.category">
        <field name="name">Medical</field>
        <field name="description">Medical Cabinet Management</field>
        <field name="sequence">10</field>
    </record>

    <record id="privilege_medical_role" model="res.groups.privilege">
        <field name="name">Rôle Médical</field>
        <field name="category_id" ref="module_category_medical"/>
        <field name="placeholder">Aucun accès</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_medical_secretary" model="res.groups">
        <field name="name">Secretary</field>
        <field name="privilege_id" ref="privilege_medical_role"/>
    </record>

    <record id="group_medical_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="privilege_id" ref="privilege_medical_role"/>
    </record>

    <record id="group_medical_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_medical_role"/>
    </record>

    <!-- Record Rules for medical.doctor -->
    <record id="rule_doctor_own_record" model="ir.rule">
        <field name="name">Doctor: Own Record Only</field>
        <field name="model_id" ref="model_medical_doctor"/>
        <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_medical_doctor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_doctor_secretary_all" model="ir.rule">
        <field name="name">Secretary: All Doctors</field>
        <field name="model_id" ref="model_medical_doctor"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_medical_secretary'))]"/>
    </record>

    <record id="rule_doctor_admin_all" model="ir.rule">
        <field name="name">Admin: All Doctors</field>
        <field name="model_id" ref="model_medical_doctor"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_medical_admin'))]"/>
    </record>

</odoo>

