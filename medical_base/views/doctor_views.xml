<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_doctor_tree" model="ir.ui.view">
        <field name="name">medical.doctor.tree</field>
        <field name="model">medical.doctor</field>
        <field name="arch" type="xml">
            <list string="Docteurs">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="specialty_id"/>
            </list>
        </field>
    </record>

    <record id="view_medical_doctor_form" model="ir.ui.view">
        <field name="name">medical.doctor.form</field>
        <field name="model">medical.doctor</field>
        <field name="arch" type="xml">
            <form string="Docteur">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="name" readonly="1"/>
                            <field name="specialty_id"/>
                        </group>
                        <group>
                            <field name="phone" class="w-100" widget="phone" placeholder="Phone"/>
                            <field name="email" class="w-100" widget="email" placeholder="Email"/>
                            <field name="user_id" readonly="not current_user_has_group('medical_base.group_medical_admin')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Biographie">
                            <field name="bio"/>
                        </page>
                        <page string="Disponibilités">
                            <field name="availability_ids">
                                <list editable="bottom">
                                    <field name="day_of_week"/>
                                    <field name="slot_ids" widget="many2many_tags"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_medical_doctor" model="ir.actions.act_window">
        <field name="name">Docteurs</field>
        <field name="res_model">medical.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>