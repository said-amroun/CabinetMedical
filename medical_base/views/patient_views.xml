<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_patient_tree" model="ir.ui.view">
        <field name="name">medical.patient.tree</field>
        <field name="model">medical.patient</field>
        <field name="arch" type="xml">
            <list string="Patients">
                <field name="name"/>
                <field name="birth_date"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <record id="view_medical_patient_form" model="ir.ui.view">
        <field name="name">medical.patient.form</field>
        <field name="model">medical.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <div class="oe_title">
                            <h1>
                                <field name="code" readonly="1"/>
                            </h1>
                        </div>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="name" readonly="1"/>
                            <field name="birth_date"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="phone" class="w-100" widget="phone" placeholder="Phone"/>
                            <field name="email" class="w-100" widget="email" placeholder="Email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Adresse">
                            <field name="address"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>


    <record id="action_medical_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">medical.patient</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>