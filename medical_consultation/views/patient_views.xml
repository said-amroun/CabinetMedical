<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_medical_patient_form_inherit_consultation" model="ir.ui.view">
        <field name="name">medical.patient.form.inherit.consultation</field>
        <field name="model">medical.patient</field>
        <field name="inherit_id" ref="medical_appointment.view_medical_patient_form_inherit_appointment"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_consultations"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-calendar"
                        groups="medical_base.group_medical_doctor,medical_base.group_medical_admin">
                    <field name="consultation_count"
                           string="Suivi Médical"
                           widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
