<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_medical_consultation_tree" model="ir.ui.view">
        <field name="name">medical.consultation.tree</field>
        <field name="model">medical.consultation</field>
        <field name="arch" type="xml">
            <list string="Consultations">
                <field name="name"/>
                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="disease_id"/>
            </list>
        </field>
    </record>

    <record id="view_medical_consultation_form" model="ir.ui.view">
        <field name="name">medical.consultation.form</field>
        <field name="model">medical.consultation</field>
        <field name="arch" type="xml">
            <form string="Consultation">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_lock" string="Verrouiller" type="object" class="btn-secondary" invisible="state != 'done'"/>
                    <button name="%(medical_consultation.action_report_prescription)d" string="Imprimer Ordonnance" type="action" class="btn-primary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,locked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="appointment_id"/>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                        </group>
                        <group>
                            <field name="consultation_date" invisible="state == 'draft'"/>
                            <field name="disease_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Préconsultation">
                            <group>
                                <group>
                                    <field name="weight"/>
                                    <field name="height"/>
                                </group>
                            </group>
                            <separator string="Soins administrés"/>
                            <field name="preconsultation_care" placeholder="Décrivez les soins administrés en préconsultation..."/>
                            <separator string="Notes"/>
                            <field name="preconsultation_notes" placeholder="Notes de préconsultation..."/>
                        </page>
                        <page string="Diagnostics">
                            <group>
                                <field name="symptoms"/>
                                <field name="notes"/>
                            </group>
                        </page>
                        <page string="Prescription">
                            <field name="prescription_line_ids">
                                <list editable="bottom">
                                    <field name="to_print"/>
                                    <field name="line_type"/>
                                    <field name="medication_id" invisible="line_type != 'medication'" required="line_type == 'medication'"/>
                                    <field name="custom_title" invisible="line_type != 'custom'" required="line_type == 'custom'" placeholder="Ex: Echodoppler"/>
                                    <field name="dosage" invisible="line_type != 'medication'" required="line_type == 'medication'"/>
                                    <field name="duration" invisible="line_type != 'medication'"/>
                                    <field name="custom_text" invisible="line_type != 'custom'" required="line_type == 'custom'" placeholder="Ex: Echodoppler des membres supérieurs..."/>
                                    <field name="note" invisible="line_type != 'medication'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Documents / Attestations">
                            <field name="document_ids">
                                <list>
                                    <field name="title"/>
                                    <field name="city"/>
                                    <field name="document_date"/>
                                    <field name="content" line_breaks="true"/>
                                    <button name="%(medical_consultation.action_report_certificate)d" string="Imprimer" type="action" icon="fa-print" class="btn-secondary"/>
                                </list>
                                <form>
                                    <header>
                                        <button name="%(medical_consultation.action_report_certificate)d" string="Imprimer" type="action" class="btn-primary" icon="fa-print"/>
                                    </header>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="template_id" options="{'no_create': True}"/>
                                                <field name="title" placeholder="Ex: Certificat médical d'aptitude, Justificatif d'absence..."/>
                                            </group>
                                            <group>
                                                <field name="city" placeholder="Ex: Aix-En-Provence"/>
                                                <field name="document_date"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="content" widget="text" placeholder="Rédigez le contenu du document ici..." class="oe_inline" style="width: 100%; min-height: 150px;"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_medical_consultation_graph" model="ir.ui.view">
        <field name="name">medical.consultation.graph</field>
        <field name="model">medical.consultation</field>
        <field name="arch" type="xml">
            <graph string="Consultations" type="bar">
                <field name="doctor_id" type="row"/>
                <field name="disease_id" type="col"/>
            </graph>
        </field>
    </record>

    <record id="view_medical_consultation_pivot" model="ir.ui.view">
        <field name="name">medical.consultation.pivot</field>
        <field name="model">medical.consultation</field>
        <field name="arch" type="xml">
            <pivot string="Consultations">
                <field name="doctor_id" type="row"/>
                <field name="disease_id" type="col"/>
                <field name="consultation_date" type="row" interval="month"/>
            </pivot>
        </field>
    </record>

    <record id="action_medical_consultation" model="ir.actions.act_window">
        <field name="name">Consultations</field>
        <field name="res_model">medical.consultation</field>
        <field name="view_mode">list,form,graph,pivot</field>
    </record>

    <!-- Inherit Doctor Form View to add address fields -->
    <record id="view_medical_doctor_form_inherit" model="ir.ui.view">
        <field name="name">medical.doctor.form.inherit</field>
        <field name="model">medical.doctor</field>
        <field name="inherit_id" ref="medical_base.view_medical_doctor_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="street"/>
                <field name="zip"/>
                <field name="city"/>
            </xpath>
        </field>
    </record>
</odoo>
