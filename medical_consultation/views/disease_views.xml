<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_medical_disease_tree" model="ir.ui.view">
        <field name="name">medical.disease.tree</field>
        <field name="model">medical.disease</field>
        <field name="arch" type="xml">
            <list string="Maladies" editable="bottom">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_medical_disease" model="ir.actions.act_window">
        <field name="name">Maladies</field>
        <field name="res_model">medical.disease</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
