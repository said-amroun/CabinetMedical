<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Action de rapport -->
    <record id="action_report_prescription" model="ir.actions.report">
        <field name="name">Ordonnance Médicale</field>
        <field name="model">medical.consultation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">medical_consultation.prescription_template</field>
        <field name="report_file">medical_consultation.prescription_template</field>
        <field name="print_report_name">'Ordonnance - %s' % object.patient_id.name</field>
        <field name="binding_model_id" ref="model_medical_consultation"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template QWeb -->
    <template id="prescription_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- En-tête : infos médecin -->
                        <div style="border-bottom: 2px solid #2c7be5; padding-bottom: 16px; margin-bottom: 24px;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <div>
                                    <h2 style="color: #2c7be5; margin: 0;">
                                        Dr. <t t-esc="doc.doctor_id.name"/>
                                    </h2>
                                    <p style="margin: 4px 0; color: #555;">
                                        <t t-esc="doc.doctor_id.specialty_id.name or 'Médecin généraliste'"/>
                                    </p>
                                    <p style="margin: 4px 0; font-size: 12px;">
                                        <t t-if="doc.doctor_id.phone">
                                            📞 <t t-esc="doc.doctor_id.phone"/>
                                        </t>
                                        <t t-if="doc.doctor_id.email">
                                            &amp;nbsp;&amp;nbsp;✉ <t t-esc="doc.doctor_id.email"/>
                                        </t>
                                    </p>
                                </div>
                                <div style="text-align: right; font-size: 12px; color: #555;">
                                    <strong>ORDONNANCE MÉDICALE</strong><br/>
                                    <t t-esc="doc.name"/><br/>
                                    Date : <t t-esc="doc.consultation_date" t-options='{"widget": "datetime", "format": "dd/MM/yyyy"}'/>
                                </div>
                            </div>
                        </div>

                        <!-- Infos patient -->
                        <div style="background: #f0f4ff; border-radius: 8px; padding: 12px 16px; margin-bottom: 24px;">
                            <strong style="color: #2c7be5;">Patient</strong><br/>
                            <span style="font-size: 14px; font-weight: bold;">
                                <t t-esc="doc.patient_id.name"/>
                            </span>
                            <t t-if="doc.patient_id.birth_date">
                                &amp;nbsp;—&amp;nbsp;Né(e) le
                                <t t-esc="doc.patient_id.birth_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                            </t>
                            <t t-if="doc.disease_id">
                                <br/>
                                <span style="color: #555; font-size: 12px;">
                                    Diagnostic : <t t-esc="doc.disease_id.name"/>
                                </span>
                            </t>
                        </div>

                        <!-- Ordonnance -->
                        <div style="margin-bottom: 32px;">
                            <h4 style="color: #2c7be5; border-bottom: 1px solid #dee2e6; padding-bottom: 6px;">
                                Prescription
                            </h4>
                            <t t-if="doc.prescription_line_ids">
                                <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
                                    <thead>
                                        <tr style="background: #2c7be5; color: white;">
                                            <th style="padding: 8px 12px; text-align: left;">#</th>
                                            <th style="padding: 8px 12px; text-align: left;">Médicament</th>
                                            <th style="padding: 8px 12px; text-align: left;">Dosage</th>
                                            <th style="padding: 8px 12px; text-align: left;">Durée</th>
                                            <th style="padding: 8px 12px; text-align: left;">Instructions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.prescription_line_ids" t-as="line">
                                            <tr t-att-style="'background: %s;' % ('#f8f9fa' if line_index % 2 == 0 else 'white')">
                                                <td style="padding: 8px 12px;"><t t-esc="line_index + 1"/></td>
                                                <td style="padding: 8px 12px; font-weight: bold;">
                                                    <t t-esc="line.medication_id.name"/>
                                                </td>
                                                <td style="padding: 8px 12px;"><t t-esc="line.dosage"/></td>
                                                <td style="padding: 8px 12px;"><t t-esc="line.duration or '—'"/></td>
                                                <td style="padding: 8px 12px; color: #555;">
                                                    <t t-esc="line.note or '—'"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <p style="color: #888; font-style: italic;">Aucun médicament prescrit.</p>
                            </t>
                        </div>

                        <!-- Notes cliniques -->
                        <t t-if="doc.notes">
                            <div style="margin-bottom: 32px;">
                                <h4 style="color: #2c7be5; border-bottom: 1px solid #dee2e6; padding-bottom: 6px;">
                                    Notes cliniques
                                </h4>
                                <p style="font-size: 13px; color: #444;"><t t-esc="doc.notes"/></p>
                            </div>
                        </t>

                        <!-- Signature -->
                        <div style="margin-top: 48px; text-align: right;">
                            <div style="display: inline-block; border-top: 1px solid #333; padding-top: 8px; min-width: 200px; text-align: center;">
                                <p style="margin: 0; font-size: 12px; color: #555;">
                                    Signature du médecin<br/>
                                    Dr. <t t-esc="doc.doctor_id.name"/>
                                </p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
