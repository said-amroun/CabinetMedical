<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Delete old stale rules -->
    <delete model="ir.rule" search="[('name', 'in', [
        'Secretary: All Consultations',
        'Doctor: All Consultations',
        'Admin: All Consultations'
    ])]"/>

    <data noupdate="0">
        <!-- Doctor: Only OWN consultations (via appointment's doctor) -->
        <record id="rule_consultation_doctor" model="ir.rule">
            <field name="name">Doctor: Own Consultations Only</field>
            <field name="model_id" ref="model_medical_consultation"/>
            <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_doctor'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Admin: Full access to ALL consultations -->
        <record id="rule_consultation_admin" model="ir.rule">
            <field name="name">Admin: All Consultations</field>
            <field name="model_id" ref="model_medical_consultation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
