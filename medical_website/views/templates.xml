    <template id="medecins" name="Medical - Nos Médecins">
        <t t-call="website.layout">
            <div class="medecins-hero">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-md-8 text-center">
                            <h1 style="color: white; font-weight: 900; font-size: 2.8rem; text-shadow: 0 2px 15px rgba(0,0,0,0.3);">Trouvez votre médecin</h1>
                            <p style="color: rgba(255,255,255,0.9); font-size: 1.1rem; margin-bottom: 30px;">Prenez rendez-vous en ligne avec nos spécialistes</p>
                            <div style="background: white; border-radius: 50px; padding: 8px 20px; display: flex; align-items: center; box-shadow: 0 8px 30px rgba(0,0,0,0.15);">
                                <svg viewBox="0 0 24 24" style="width: 22px; fill: #9c27b0; margin-right: 10px; flex-shrink: 0;">
                                    <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                                </svg>
                                <input type="text" id="search-doctor" placeholder="Rechercher par nom ou spécialité..." style="border: none; outline: none; width: 100%; font-size: 1rem; color: #333;"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div style="background: #f8f4fc; min-height: 60vh; padding: 40px 0;">
                <div class="container">
                    <p style="color: #8e7b9a; margin-bottom: 25px; font-size: 0.95rem;">
                        <strong style="color: var(--medical-dark);" id="doctor-count"><t t-esc="len(doctors)"/></strong> médecin(s) disponible(s)
                    </p>
                    <div id="doctors-list">
                        <t t-foreach="doctors" t-as="doctor">
                            <div class="doctolib-card"
                                 t-att-data-name="doctor.name.lower()"
                                 t-att-data-specialty="doctor.specialty_id.name.lower() if doctor.specialty_id else ''">
                                <div class="doctolib-card-left">
                                    <div class="doctolib-avatar">
                                        <svg viewBox="0 0 24 24" style="width: 45px; fill: white;">
                                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="doctolib-card-middle">
                                    <div class="doctolib-specialty-tag">
                                        <t t-esc="doctor.specialty_id.name if doctor.specialty_id else 'Médecin généraliste'"/>
                                    </div>
                                    <h4 class="doctolib-name">Dr. <t t-esc="doctor.name"/></h4>
                                    <p class="doctolib-bio">
                                        <t t-esc="doctor.bio if doctor.bio else 'Médecin expérimenté et dévoué à votre santé et bien-être.'"/>
                                    </p>
                                    <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                                        <t t-if="doctor.phone">
                                            <span style="color: #8e7b9a; font-size: 0.85rem; display: flex; align-items: center; gap: 5px;">
                                                <svg viewBox="0 0 24 24" style="width: 14px; fill: var(--medical-secondary);">
                                                    <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                                                </svg>
                                                <t t-esc="doctor.phone"/>
                                            </span>
                                        </t>
                                        <t t-if="doctor.email">
                                            <span style="color: #8e7b9a; font-size: 0.85rem; display: flex; align-items: center; gap: 5px;">
                                                <svg viewBox="0 0 24 24" style="width: 14px; fill: var(--medical-secondary);">
                                                    <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                                                </svg>
                                                <t t-esc="doctor.email"/>
                                            </span>
                                        </t>
                                    </div>
                                </div>
                                <div class="doctolib-card-right">
                                    <p style="color: #43a047; font-weight: 700; font-size: 0.9rem; margin-bottom: 15px;">Disponible en ligne</p>
                                    <a t-att-href="'/medical/rdv?doctor_id=' + str(doctor.id)" class="btn btn-medical" style="width: 100%; padding: 12px; font-size: 0.95rem;">
                                        Prendre RDV
                                    </a>
                                    <p style="color: #8e7b9a; font-size: 0.8rem; text-align: center; margin-top: 10px;">Consultation en cabinet</p>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    var searchInput = document.getElementById('search-doctor');
                    var cards = document.querySelectorAll('.doctolib-card');
                    var countEl = document.getElementById('doctor-count');
                    if (searchInput) {
                        searchInput.addEventListener('input', function() {
                            var query = this.value.toLowerCase();
                            var visible = 0;
                            cards.forEach(function(card) {
                                var name = card.getAttribute('data-name') || '';
                                var specialty = card.getAttribute('data-specialty') || '';
                                if (!query || name.includes(query) || specialty.includes(query)) {
                                    card.style.display = 'flex';
                                    visible++;
                                } else {
                                    card.style.display = 'none';
                                }
                            });
                            if (countEl) countEl.textContent = visible;
                        });
                    }
                });
            </script>
        </t>
    </template>

    <template id="rdv" name="Medical - Rendez-vous">
        <t t-call="website.layout">
            <div style="background: var(--medical-gradient); padding: 60px 0; text-align: center; color: white;">
                <h1 style="font-size: 2.5rem; font-weight: 800; margin: 0; color: white; text-shadow: 0 2px 15px rgba(0,0,0,0.4);">Prendre un rendez-vous</h1>
                <p style="color: rgba(255,255,255,0.95); margin-top: 10px; text-shadow: 0 1px 8px rgba(0,0,0,0.3);">Remplissez le formulaire ci-dessous pour réserver votre consultation</p>
            </div>

            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">

                        <t t-if="error">
                            <div class="alert alert-danger mb-4" style="border-radius: 12px; border: none; background: #fce4ec; color: #880e4f;">
                                <strong>Erreur :</strong> <t t-esc="error"/>
                            </div>
                        </t>

                        <t t-if="selected_doctor">
                            <div class="medical-card p-4 mb-4 text-center" style="background: var(--medical-light);">
                                <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--medical-gradient); display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                                    <svg viewBox="0 0 24 24" style="width: 40px; fill: white;">
                                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                    </svg>
                                </div>
                                <h4 style="color: var(--medical-dark); font-weight: 800;">Dr. <t t-esc="selected_doctor.name"/></h4>
                                <p style="color: var(--medical-secondary); font-weight: 600;">
                                    <t t-esc="selected_doctor.specialty_id.name if selected_doctor.specialty_id else 'Médecin généraliste'"/>
                                </p>
                                <a href="/medical/medecins" style="color: var(--medical-primary); font-size: 0.9rem;">Changer de médecin</a>
                            </div>
                        </t>

                        <div class="medical-card p-5">
                            <form action="/medical/rdv/submit" method="post" class="rdv-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="doctor_id" t-if="selected_doctor" t-att-value="str(selected_doctor.id)"/>

                                <h5 class="mb-4" style="color: var(--medical-dark); font-weight: 800; border-left: 4px solid var(--medical-secondary); padding-left: 12px;">Vos informations</h5>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Prénom *</label>
                                        <input type="text" name="first_name" class="form-control" required="1"
                                               placeholder="Votre prénom"
                                               t-att-value="form_data.get('first_name', '') if form_data else ''"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Nom *</label>
                                        <input type="text" name="last_name" class="form-control" required="1"
                                               placeholder="Votre nom"
                                               t-att-value="form_data.get('last_name', '') if form_data else ''"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Téléphone</label>
                                        <input type="tel" name="phone" class="form-control"
                                               placeholder="Votre numéro"
                                               t-att-value="form_data.get('phone', '') if form_data else ''"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Email</label>
                                        <input type="email" name="email" class="form-control"
                                               placeholder="Votre email"
                                               t-att-value="form_data.get('email', '') if form_data else ''"/>
                                    </div>
                                </div>

                                <h5 class="mb-4 mt-4" style="color: var(--medical-dark); font-weight: 800; border-left: 4px solid var(--medical-secondary); padding-left: 12px;">Votre rendez-vous</h5>

                                <div class="mb-4">
                                    <label class="form-label fw-bold">Date et heure *</label>
                                    <input type="datetime-local" name="appointment_date"
                                           class="form-control" required="1" id="appointment_date"
                                           t-att-value="form_data.get('appointment_date', '') if form_data else ''"/>
                                    <small class="text-muted">Disponible du lundi au vendredi, entre 08h00 et 17h00</small>
                                </div>

                                <button type="submit" class="btn btn-medical w-100" style="padding: 16px; font-size: 1.1rem;">
                                    Confirmer le rendez-vous
                                </button>
                            </form>
                        </div>

                        <div class="text-center mt-3">
                            <a href="/medical/medecins" style="color: var(--medical-primary);">Voir tous nos médecins</a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="confirmation" name="Medical - Confirmation RDV">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-8 text-center">
                        <div class="medical-card p-5">
                            <h2>Rendez-vous confirmé</h2>
                            <p class="text-muted mb-4">Votre rendez-vous a été enregistré avec succès.</p>
                            <table class="table table-bordered text-start mb-4">
                                <tr>
                                    <td><strong>Référence</strong></td>
                                    <td><t t-esc="rdv.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Patient</strong></td>
                                    <td><t t-esc="rdv.patient_id.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Médecin</strong></td>
                                    <td><t t-esc="rdv.doctor_id.name"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Spécialité</strong></td>
                                    <td><t t-esc="rdv.doctor_id.specialty_id.name or 'N/A'"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Date et heure</strong></td>
                                    <td><t t-esc="rdv.appointment_date" t-options='{"widget": "datetime"}'/></td>
                                </tr>
                            </table>
                            <a t-att-href="'/medical/rdv/pdf/' + str(rdv.id)" class="btn btn-medical btn-lg mb-3">
                                Télécharger la confirmation PDF
                            </a>
                            <br/>
                            <a href="/medical/medecins" class="btn btn-outline-secondary">
                                Prendre un autre rendez-vous
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="contact" name="Medical - Contact">
        <t t-call="website.layout">
            <div style="background: var(--medical-gradient); padding: 60px 0; text-align: center; color: white;">
                <h1 style="font-size: 2.5rem; font-weight: 800; margin: 0; color: white; text-shadow: 0 2px 15px rgba(0,0,0,0.4);">Contactez-nous</h1>
                <p style="color: rgba(255,255,255,0.95); margin-top: 10px;">Une question ? N'hésitez pas à nous écrire</p>
            </div>
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <t t-if="success">
                            <div class="alert alert-success mb-4" style="border-radius: 12px;">
                                Votre message a été envoyé avec succès. Nous vous répondrons rapidement.
                            </div>
                        </t>
                        <t t-if="error">
                            <div class="alert alert-danger mb-4" style="border-radius: 12px;">
                                <t t-esc="error"/>
                            </div>
                        </t>
                        <div class="medical-card p-5">
                            <form action="/medical/contact/submit" method="post" class="rdv-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Nom complet *</label>
                                        <input type="text" name="name" class="form-control" required="1" placeholder="Votre nom"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Email *</label>
                                        <input type="email" name="email" class="form-control" required="1" placeholder="Votre email"/>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Sujet</label>
                                    <input type="text" name="subject" class="form-control" placeholder="Sujet de votre message"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Message *</label>
                                    <textarea name="message" class="form-control" rows="6" required="1" placeholder="Votre message..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-medical w-100 mt-3" style="padding: 16px; font-size: 1.1rem;">
                                    Envoyer le message
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="mes_rdv" name="Medical - Mes Rendez-vous">
        <t t-call="website.layout">
            <div style="background: var(--medical-gradient); padding: 60px 0; text-align: center; color: white;">
                <h1 style="font-size: 2.5rem; font-weight: 800; margin: 0; color: white; text-shadow: 0 2px 15px rgba(0,0,0,0.4);">Mes rendez-vous</h1>
                <p style="color: rgba(255,255,255,0.95); margin-top: 10px;">Retrouvez l'historique de vos rendez-vous</p>
            </div>
            <div class="container mt-5 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="medical-card p-5 mb-4">
                            <h5 style="color: var(--medical-dark); font-weight: 800; border-left: 4px solid var(--medical-secondary); padding-left: 12px; margin-bottom: 25px;">Vos informations</h5>
                            <form action="/medical/mes-rdv/search" method="post" class="rdv-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Prénom *</label>
                                        <input type="text" name="first_name" class="form-control" required="1" placeholder="Votre prénom"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Nom *</label>
                                        <input type="text" name="last_name" class="form-control" required="1" placeholder="Votre nom"/>
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Référence du rendez-vous *</label>
                                    <input type="text" name="reference" class="form-control" required="1" placeholder="Ex: APT/00001"/>
                                </div>
                                <button type="submit" class="btn btn-medical w-100" style="padding: 16px; font-size: 1.1rem;">
                                    Rechercher mes rendez-vous
                                </button>
                            </form>
                        </div>

                        <t t-if="error">
                            <div class="alert alert-danger" style="border-radius: 12px;">
                                <t t-esc="error"/>
                            </div>
                        </t>

                        <t t-if="searched and rdvs">
                            <h4 class="mb-3" style="color: var(--medical-dark); font-weight: 800;">
                                Rendez-vous de <t t-esc="patient.name"/>
                            </h4>
                            <div class="table-responsive">
                                <table class="table table-bordered" style="border-radius: 12px; overflow: hidden;">
                                    <thead style="background: var(--medical-gradient); color: white;">
                                        <tr>
                                            <th>Référence</th>
                                            <th>Médecin</th>
                                            <th>Date</th>
                                            <th>Statut</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="rdvs" t-as="rdv">
                                            <tr>
                                                <td><t t-esc="rdv.name"/></td>
                                                <td><t t-esc="rdv.doctor_id.name"/></td>
                                                <td><t t-esc="rdv.appointment_date" t-options='{"widget": "datetime"}'/></td>
                                                <td>
                                                    <span t-attf-class="badge bg-#{'success' if rdv.state == 'done' else 'primary' if rdv.state == 'confirmed' else 'warning' if rdv.state == 'draft' else 'danger'}">
                                                        <t t-esc="rdv.state"/>
                                                    </span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>