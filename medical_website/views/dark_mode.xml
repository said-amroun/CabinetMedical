<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dark_mode_assets" inherit_id="website.layout" name="Dark Mode Assets" priority="1">
        <xpath expr="//head" position="inside">
            <script type="text/javascript">
                (function() {
                    try {
                        if (localStorage.getItem('medicss_dark') === 'true') {
                            document.documentElement.classList.add('dark-mode');
                        }
                    } catch(e) {}
                })();
            </script>
            <style>
                html.dark-mode,
                html.dark-mode body,
                html.dark-mode #wrapwrap,
                html.dark-mode main { background-color: #14101f !important; }
                html.dark-mode .mesrdv-page,
                html.dark-mode .espace-page { background: linear-gradient(160deg, #14101f 0%, #1a1428 100%) !important; }
                html.dark-mode { color-scheme: dark; }
            </style>
        </xpath>
    </template>
</odoo>