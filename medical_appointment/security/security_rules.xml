<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Delete old stale rules that had noupdate=1 -->
    <function model="ir.rule" name="search">
        <value eval="[('name', 'in', [
            'Secretary: All Appointments',
            'Doctor: Own Appointments',
            'Admin: All Appointments'
        ])]"/>
    </function>
    <delete model="ir.rule" search="[('name', 'in', [
        'Secretary: All Appointments',
        'Doctor: Own Appointments',
        'Admin: All Appointments'
    ])]"/>

    <data noupdate="0">
        <!-- Secretary: Full access to ALL appointments -->
        <record id="rule_appointment_secretary" model="ir.rule">
            <field name="name">Secretary: All Appointments</field>
            <field name="model_id" ref="model_medical_appointment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_secretary'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Doctor: Only OWN appointments (where doctor_id.user_id = current user) -->
        <record id="rule_appointment_doctor" model="ir.rule">
            <field name="name">Doctor: Own Appointments Only</field>
            <field name="model_id" ref="model_medical_appointment"/>
            <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_doctor'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Admin: Full access to ALL appointments -->
        <record id="rule_appointment_admin" model="ir.rule">
            <field name="name">Admin: All Appointments</field>
            <field name="model_id" ref="model_medical_appointment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
