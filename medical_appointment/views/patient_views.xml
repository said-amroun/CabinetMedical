<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_medical_patient_form_inherit_appointment" model="ir.ui.view">
        <field name="name">medical.patient.form.inherit.appointment</field>
        <field name="model">medical.patient</field>
        <field name="inherit_id" ref="medical_base.view_medical_patient_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-calendar"
                        type="object" name="action_view_appointments">
                    <field name="appointment_count" widget="statinfo" string="Rendez-vous"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
