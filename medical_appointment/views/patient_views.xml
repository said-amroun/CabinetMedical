<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_patient_form_inherit_appointment" model="ir.ui.view">
        <field name="name">medical.patient.form.inherit.appointment</field>
        <field name="model">medical.patient</field>
        <field name="inherit_id" ref="medical_base.view_medical_patient_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header/>
            </xpath>
            <xpath expr="//sheet/group" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_appointments_not_done"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-calendar-o">
                        <field name="appointment_not_done_count"
                               string="Rendez-vous"
                               widget="statinfo"/>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
