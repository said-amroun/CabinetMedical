<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_appointment_tree" model="ir.ui.view">
        <field name="name">medical.appointment.tree</field>
        <field name="model">medical.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_medical_appointment_form" model="ir.ui.view">
        <field name="name">medical.appointment.form</field>
        <field name="model">medical.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Terminer" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Annuler" type="object" invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                        </group>
                        <group>
                            <field name="appointment_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_medical_appointment_calendar" model="ir.ui.view">
        <field name="name">medical.appointment.calendar</field>
        <field name="model">medical.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="appointment_date" date_delay="duration" color="doctor_id" mode="week" quick_create="0">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="action_medical_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">medical.appointment</field>
        <field name="view_mode">list,calendar,form</field>
    </record>

</odoo>
