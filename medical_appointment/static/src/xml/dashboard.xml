<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="medical_appointment.Dashboard" owl="1">
        <div class="o_medical_dashboard container mt-4">
            <t t-if="!state.has_access">
                <div class="row">
                    <div class="col-12 text-center mt-5">
                        <div class="alert alert-danger shadow-sm d-inline-block p-4">
                            <i class="fa fa-lock fa-3x mb-3 text-danger"></i>
                            <h2 class="text-danger">Accès Refusé</h2>
                            <p class="lead mb-0">Vous n'êtes pas autorisé à accéder au module Médical.</p>
                            <p><strong>Contactez votre administrateur pour demander l'accès.</strong></p>
                        </div>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div class="row">
                <div class="col-12">
                    <h1 class="text-primary mb-3">
                        Bienvenue <t t-esc="session.name"/>
                    </h1>
                    <h3 class="mt-4 mb-3 text-dark fw-bold">
                        <t t-if="state.is_doctor">
                            Voici votre planning pour aujourd'hui :
                        </t>
                        <t t-else="">
                            Voici tous les rendez-vous d'aujourd'hui :
                        </t>
                    </h3>
                </div>
            </div>
            
            <div class="row mt-4">
                <div class="col-12">
                    <t t-if="state.appointments.length > 0">
                        <div class="position-relative" style="padding-left: 20px;">
                            <!-- Vertical timeline line -->
                            <div class="position-absolute bg-primary" style="left: 0; top: 15px; bottom: 15px; width: 4px; border-radius: 2px; opacity: 0.2;"></div>
                            
                            <div class="d-flex flex-column gap-3">
                                <t t-foreach="state.appointments" t-as="app" t-key="app.id">
                                    <div class="card shadow-sm border-0 position-relative" t-on-click="() => this.openConsultation(app.id)" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.01)'" onmouseout="this.style.transform='scale(1)'">
                                        <!-- Timeline dot -->
                                        <div class="position-absolute bg-primary rounded-circle" style="left: -26px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; border: 3px solid white; z-index: 1;"></div>
                                        
                                        <div class="card-body d-flex align-items-center rounded"
                                             t-attf-style="border-left: 5px solid {{ app.state === 'draft' ? '#6c757d' : app.state === 'confirmed' ? '#0dcaf0' : '#198754' }}">
                                            
                                            <!-- Time column -->
                                            <div class="me-4 text-center" style="min-width: 80px;">
                                                <h4 class="mb-0 text-primary fw-bold"><t t-esc="app.time_display"/></h4>
                                            </div>
                                            
                                            <!-- Info column -->
                                            <div class="flex-grow-1">
                                                <h5 class="mb-1 text-dark fw-bold"><t t-esc="app.patient_id[1]"/></h5>
                                                <p class="mb-0 text-muted small">
                                                    <i class="fa fa-tag me-1"></i>
                                                    <span class="me-3">Ref: <t t-esc="app.name"/></span>
                                                    
                                                    <t t-if="!state.is_doctor">
                                                        <i class="fa fa-user-md me-1"></i>
                                                        Médecin: <t t-esc="app.doctor_id[1]"/>
                                                    </t>
                                                </p>
                                            </div>
                                            
                                            <!-- Status column -->
                                            <div class="ms-3 text-end">
                                                <span t-attf-class="badge rounded-pill px-3 py-2 #{app.state === 'draft' ? 'bg-secondary' : app.state === 'confirmed' ? 'bg-info text-dark' : 'bg-success'}">
                                                    <t t-if="app.state === 'draft'">Brouillon</t>
                                                    <t t-elif="app.state === 'confirmed'">Confirmé</t>
                                                    <t t-elif="app.state === 'done'">Terminé</t>
                                                    <t t-else=""><t t-esc="app.state"/></t>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-info shadow-sm">
                            <i class="fa fa-info-circle me-2"></i> Vous n'avez aucun rendez-vous de prévu pour aujourd'hui.
                        </div>
                    </t>
                </div>
            </div>
            </t>
        </div>
    </t>
</templates>
