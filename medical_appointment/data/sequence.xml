<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="seq_medical_appointment" model="ir.sequence">
        <field name="name">Medical Appointment Sequence</field>
        <field name="code">medical.appointment</field>
        <field name="prefix"></field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_medical_doctor" model="ir.sequence">
        <field name="name">Medical doctor Sequence</field>
        <field name="code">medical.doctor</field>
        <field name="prefix">DOC/</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_medical_patient" model="ir.sequence">
        <field name="name">Medical patient Sequence</field>
        <field name="code">medical.patient</field>
        <field name="prefix">PAT/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
