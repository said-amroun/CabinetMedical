<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="email_template_appointment_confirmation" model="mail.template">
            <field name="name">Confirmation de Rendez-vous Médical</field>
            <field name="model_id" ref="medical_appointment.model_medical_appointment"/>
            <field name="subject">✅ Votre rendez-vous est confirmé — {{ object.name }}</field>
            <field name="email_from">{{ object.doctor_id.email or user.email }}</field>
            <field name="email_to">{{ object.patient_id.email }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #f9f9f9; border-radius: 10px; overflow: hidden;">

    <!-- En-tête -->
    <div style="background: linear-gradient(135deg, #2c7be5, #1a5cbf); padding: 32px; text-align: center;">
        <h1 style="color: white; margin: 0; font-size: 22px;">🏥 Cabinet Médical</h1>
        <p style="color: #cfe2ff; margin: 8px 0 0;">Confirmation de votre rendez-vous</p>
    </div>

    <!-- Corps -->
    <div style="padding: 32px; background: white;">
        <p style="font-size: 16px; color: #333;">
            Bonjour <strong>{{ object.patient_id.name }}</strong>,
        </p>
        <p style="color: #555;">
            Votre rendez-vous a été <strong style="color: #28a745;">confirmé</strong>.
            Voici le récapitulatif :
        </p>

        <!-- Carte RDV -->
        <div style="background: #f0f4ff; border-left: 4px solid #2c7be5; border-radius: 6px; padding: 20px; margin: 24px 0;">
            <table style="width: 100%; border-collapse: collapse;">
                <tr>
                    <td style="padding: 6px 0; color: #888; width: 40%;">📋 Référence</td>
                    <td style="padding: 6px 0; font-weight: bold; color: #333;">{{ object.name }}</td>
                </tr>
                <tr>
                    <td style="padding: 6px 0; color: #888;">👨‍⚕️ Médecin</td>
                    <td style="padding: 6px 0; font-weight: bold; color: #333;">Dr. {{ object.doctor_id.name }}</td>
                </tr>
                <tr>
                    <td style="padding: 6px 0; color: #888;">🩺 Spécialité</td>
                    <td style="padding: 6px 0; color: #333;">{{ object.doctor_id.specialty_id.name or 'Médecine générale' }}</td>
                </tr>
                <tr>
                    <td style="padding: 6px 0; color: #888;">📅 Date &amp; Heure</td>
                    <td style="padding: 6px 0; font-weight: bold; color: #2c7be5;">
                        {{ object.appointment_date | format_datetime(dt_format='EEEE dd MMMM yyyy à HH:mm', lang_code=object.env.lang or 'fr_FR') }}
                    </td>
                </tr>
            </table>
        </div>

        <p style="color: #555; font-size: 14px;">
            Merci de vous présenter <strong>10 minutes avant</strong> l'heure de votre rendez-vous.<br/>
            En cas d'empêchement, veuillez nous contacter dès que possible.
        </p>
    </div>

    <!-- Pied de page -->
    <div style="background: #f0f4ff; padding: 16px 32px; text-align: center; font-size: 12px; color: #888;">
        <p style="margin: 0;">Cabinet Médical — Cet email est généré automatiquement, merci de ne pas y répondre.</p>
    </div>

</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
